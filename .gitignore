/target
Cargo.lock.bak
*.tmp
.DS_Store

# Local working files (not tracked).
/docs/
/scripts/
/CLAUDE.md

# Never commit attestation credentials / decode keys / service-account JSON.
*.p8
*-service-account*.json
/secrets/

# Local filled-in config (real project values + secrets path) — never commit.
/octet-attest-verify.toml

# Captured device vectors hold real tokens/attestations from a live device —
# never commit (see test-vectors/appattest/README.md). Helper scripts + READMEs
# under test-vectors/ stay tracked; only the captured artifacts are ignored.
/test-vectors/appattest/*.bin
/test-vectors/appattest/meta.txt
/test-vectors/playintegrity/
